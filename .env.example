# Google Gemini API Key (Required)
# Get a free key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_google_gemini_api_key_here

# Backend Server Configuration (Optional)
PORT=8000
HOST=0.0.0.0

# Frontend Environment Variables (Loaded by Vite)
# Note: In production docker setup, these can be set accordingly
VITE_API_URL=http://localhost:8000/api

# SMTP Email Notification Configuration (Optional)
# If configured, contact form submissions will trigger real emails to anupamsingh8095@gmail.com
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password-or-token
